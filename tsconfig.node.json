{
  "compilerOptions": {
    "jsx": "preserve",
    "lib": [
      "ESNext"
    ],
    "module": "NodeNext",
    "strict": true,
    "strictNullChecks": true,
    "verbatimModuleSyntax": true,
    "target": "ESNext",
    "declaration": true,
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declarationMap": true,
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "noEmit": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "rslib.config.ts",
    "lynx.config.ts",
    "vitest.config.ts"
  ]
}
