{
  "compilerOptions": {
    "jsx": "preserve",
    "lib": [
      "ESNext"
    ],
    "module": "ESNext",
    "strict": true,
    "strictNullChecks": true,
    "verbatimModuleSyntax": true,
    "target": "ESNext",
    "declaration": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declarationMap": true,
    "incremental": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src"
  ]
}
